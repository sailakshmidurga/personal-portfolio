# ─── EmailJS Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values from EmailJS dashboard.
# Never commit the .env file — it is already in .gitignore.

# Step 1: Go to https://www.emailjs.com and create a free account.
# Step 2: Add a new Email Service (Gmail recommended) → copy the Service ID below.
VITE_EMAILJS_SERVICE_ID=your_service_id_here

# Step 3: Create a new Email Template → copy the Template ID below.
# In your template, use these variables: {{from_name}}, {{from_email}}, {{subject}}, {{message}}
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here

# Step 4: Go to Account → API Keys → copy your Public Key below.
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
